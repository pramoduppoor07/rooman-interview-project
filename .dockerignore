# Version control
.git/
.gitignore

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/

# Environment secrets — injected at runtime via docker-compose or -e flag
.env

# Generated outputs — mounted as volumes or regenerated at container start
samples/generated/
results/

# Dev / editor artifacts
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/

# Docker files themselves (no need to copy into image)
Dockerfile
docker-compose.yml
.dockerignore
